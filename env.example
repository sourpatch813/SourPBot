# ─── TWITCH ───────────────────────────────────────────────
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_BROADCASTER_ID=your_numeric_twitch_user_id
TWITCH_CHANNEL_NAME=your_twitch_username

# ─── DISCORD ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token

# The channel IDs where each type of notification posts
DISCORD_LIVE_CHANNEL_ID=your_go_live_channel_id
DISCORD_REDEEMS_CHANNEL_ID=your_channel_points_channel_id

# Optional: role ID to ping when you go live (leave blank to skip)
DISCORD_PING_ROLE_ID=

# ─── EVENTSUB (for channel points + stream events) ────────
# A public HTTPS URL that Twitch can reach (use ngrok for local testing)
# Example: https://abc123.ngrok.io
EVENTSUB_CALLBACK_URL=https://your-public-url.com
EVENTSUB_SECRET=make_up_any_random_string_here
PORT=3000
